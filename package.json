{
  "name": "paperback-manga-sources",
  "version": "1.0.0",
  "private": true,
  "repositoryName": "Paperback Manga Sources",
  "description": "Paperback v0.8 source repository for multiple manga scan sites.",
  "scripts": {
    "generate-version": "node scripts/generate-version.js",
    "pretypecheck": "npm run generate-version",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run generate-version",
    "build": "paperback bundle",
    "prebundle": "npm run generate-version",
    "bundle": "paperback bundle",
    "preserve": "npm run generate-version",
    "serve": "paperback serve"
  },
  "keywords": [
    "paperback",
    "paperback-extension",
    "omegascans",
    "mangadistrict"
  ],
  "license": "MIT",
  "devDependencies": {
    "@paperback/toolchain": "0.8.0-alpha.38",
    "@paperback/types": "0.8.0-alpha.38",
    "@types/node": "^18.11.9",
    "typescript": "^4.8.3"
  }
}
